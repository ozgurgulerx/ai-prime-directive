---
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN || "ozgurguler.org";
const plausibleScriptSrc = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_SRC || "https://plausible.io/js/script.js";
const usesAccountSnippet = Boolean(import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_SRC);
---

{usesAccountSnippet ? (
  <script defer src={plausibleScriptSrc}></script>
) : (
  <script defer data-domain={plausibleDomain} src={plausibleScriptSrc}></script>
)}

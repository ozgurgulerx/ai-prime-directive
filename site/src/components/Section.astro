---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  href?: string;
  linkLabel?: string;
}

const { eyebrow, title, intro, href, linkLabel = "View all" } = Astro.props;
---

<section class="section">
  <div class="section-head">
    <div>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2>{title}</h2>
      {intro && <p>{intro}</p>}
    </div>
    {href && <a class="button" href={href}>{linkLabel}</a>}
  </div>
  <slot />
</section>

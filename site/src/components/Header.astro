---
import { withBase } from "@/lib/links";

const nav = [
  ["Agents", "agents/"],
  ["Inference", "inference/"],
  ["Build Log", "build-log/"],
  ["Blog", "blog/"],
  ["Books", "books/"],
  ["Talks", "talks/"],
  ["Consulting", "consulting/"],
  ["Investments", "investments/"],
];
---

<header class="site-header">
  <nav class="nav" aria-label="Primary">
    <a class="brand" href={withBase()}>Ozgur Guler</a>
    <div class="nav-links">
      {nav.map(([label, href]) => <a href={withBase(href)}>{label}</a>)}
    </div>
  </nav>
</header>

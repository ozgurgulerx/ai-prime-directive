---
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  title: string;
  date?: Date;
  summary?: string;
  tags?: string[];
  sourceUrl?: string;
  publication?: string;
  pinned?: boolean;
}

const { title, date, summary, tags = [], sourceUrl, publication, pinned = false } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <article class="prose">
    <p class="eyebrow">{date ? date.toISOString().slice(0, 10) : "Note"}</p>
    <h1>{title}</h1>
    {summary && <p class="lede">{summary}</p>}
    {tags.length > 0 && <div class="chips">{tags.map((tag) => <span class="chip">{tag}</span>)}</div>}
    {(sourceUrl || publication || pinned) && (
      <p>
        {pinned && <span class="status">Pinned</span>}
        {publication && <span class="status">{publication}</span>}
        {sourceUrl && <a class="button primary" href={sourceUrl} target="_blank" rel="noopener">Read on Medium</a>}
      </p>
    )}
    <slot />
  </article>
</BaseLayout>

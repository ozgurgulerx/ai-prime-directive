---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/links";

const guideItems = [
  {
    title: "Build Log",
    blurb: "For personal projects, AI agents, LLM inference, and practical system notes.",
    href: withBase("build-log/"),
    kind: "projects",
  },
  {
    title: "Books",
    blurb: "For free in-progress AI book drafts and source Google Docs.",
    href: withBase("books/"),
    kind: "drafts",
  },
  {
    title: "Blog",
    blurb: "For essays, Medium posts, and longer technical writing.",
    href: withBase("blog/"),
    kind: "writing",
  },
  {
    title: "Talks",
    blurb: "For workshops, speaking topics, and session material.",
    href: withBase("talks/"),
    kind: "speaking",
  },
  {
    title: "Startups",
    blurb: "For public-safe startup, VC, and technical diligence notes.",
    href: withBase("investments/"),
    kind: "vc / startups",
  },
  {
    title: "Consulting",
    blurb: "For focused advisory formats around applied AI systems.",
    href: withBase("consulting/"),
    kind: "advisory",
  },
];
---

<BaseLayout
  title="AI Systems Builder"
  description="Özgür Güler — Microsoft Innovation Hub technical lead in Istanbul, building and writing about production AI systems, agents, inference, EvalOps, and AI infrastructure."
>
  <header class="masthead" aria-label="Masthead">
    <span>Istanbul</span>
    <span class="rule"></span>
    <span>Microsoft Innovation Hub</span>
    <span class="rule"></span>
    <a class="plausible-event-name=email_click" href="mailto:ozgur@graph-atlas.com">Reach →</a>
  </header>

  <section class="hero">
    <p class="eyebrow">Özgür Güler · AI systems builder</p>
    <h1>Innovation Hub by Day, <em>AI Systems Builder by Night.</em></h1>
    <p class="lede">
      I build production AI systems — agentic workflows, model serving, EvalOps, governance,
      and the infrastructure decisions that make deployments hold up outside the demo.
    </p>
    <p class="lede-aside">
      Alongside that: continual-learning AI books, public build logs, ENA.VC technical
      diligence, and applied-AI architecture with startup teams.
    </p>
  </section>

  <figure class="home-portrait">
    <img src={withBase("images/speaking/infobip-zagreb.jpeg")} alt="Özgür Güler speaking during an AI workshop." loading="eager" decoding="async" />
    <figcaption>Technical workshops on enterprise AI, agentic systems, and trustworthy deployment.</figcaption>
  </figure>

  <dl class="now-strip" aria-label="Profile facts">
    <dt>Based</dt>
    <dd>Istanbul.</dd>
    <dt>By day</dt>
    <dd>MS Innovation Hub technical lead.</dd>
    <dt>By night</dt>
    <dd>Books, build logs, and public experiments.</dd>
    <dt>Focus</dt>
    <dd>AI agents · LLM inference · EvalOps · startup diligence.</dd>
  </dl>

  <section class="section" aria-labelledby="start-here">
    <div class="section-head">
      <div>
        <span class="section-marker" aria-hidden="true">I.</span>
        <p class="eyebrow">Start here</p>
        <h2 id="start-here">Choose the Right Shelf</h2>
        <p>This landing page stays simple. The work itself lives in the sections below.</p>
      </div>
    </div>
    <ol class="index-list">
      {guideItems.map((item, index) => (
        <li>
          <a href={item.href}>
            <span class="idx-num">№&nbsp;{String(index + 1).padStart(2, "0")}</span>
            <span>
              <span class="idx-title">{item.title}</span>
              <span class="idx-blurb">{item.blurb}</span>
            </span>
            <span class="idx-kind">{item.kind}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="colophon" aria-labelledby="colophon">
    <div>
      <p class="col-mark" id="colophon">Özgür Güler<br /><em>AI Systems Builder.</em></p>
      <p class="col-meta">
        Est. MMXXIV<br />
        Set in <em>Newsreader</em>, Inter, &amp; JetBrains&nbsp;Mono.<br />
        Privacy-first analytics · No nonsense.
      </p>
    </div>
    <div class="col-reach">
      <h3>Reach</h3>
      <div class="col-links">
        <a class="plausible-event-name=email_click" href="mailto:ozgur@graph-atlas.com">email</a>
        <a href="https://github.com/ozgurgulerx" target="_blank" rel="noopener">github</a>
        <a href="https://medium.com/@343544" target="_blank" rel="noopener">medium</a>
        <a href="https://generativefrontier.substack.com" target="_blank" rel="noopener">substack</a>
        <a href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7267852565411737601" target="_blank" rel="noopener">linkedin</a>
        <a href="https://x.com/ozgurgulerx" target="_blank" rel="noopener">x.com</a>
      </div>
    </div>
  </section>
</BaseLayout>

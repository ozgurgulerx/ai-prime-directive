---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/links";

const guideItems = [
  {
    title: "Build Log",
    blurb: "For personal projects, AI agents, LLM inference, and practical system notes.",
    href: withBase("build-log/"),
    kind: "projects",
  },
  {
    title: "Books",
    blurb: "For free in-progress AI book drafts and source Google Docs.",
    href: withBase("books/"),
    kind: "drafts",
  },
  {
    title: "Blog",
    blurb: "For essays, Medium posts, and longer technical writing.",
    href: withBase("blog/"),
    kind: "writing",
  },
  {
    title: "Talks",
    blurb: "For workshops, speaking topics, and session material.",
    href: withBase("talks/"),
    kind: "speaking",
  },
  {
    title: "Startups",
    blurb: "For public-safe startup, VC, and technical diligence notes.",
    href: withBase("investments/"),
    kind: "vc / startups",
  },
  {
    title: "Consulting",
    blurb: "For focused advisory formats around applied AI systems.",
    href: withBase("consulting/"),
    kind: "advisory",
  },
];
---

<BaseLayout
  title="AI Systems Builder"
  description="Özgür Güler — AI Tech Lead at Microsoft Innovation Hub, Istanbul, focused on AI inference systems, production AI agents, EvalOps, and cloud AI architecture."
>
  <header class="masthead" aria-label="Masthead">
    <span>Istanbul</span>
    <span class="rule"></span>
    <span>Microsoft Innovation Hub</span>
    <span class="rule"></span>
    <a class="plausible-event-name=email_click" href="mailto:ozgur@graph-atlas.com">Reach →</a>
  </header>

  <section class="hero">
    <p class="eyebrow">Özgür Güler · AI systems builder</p>
    <h1>AI Tech Lead, Inference Systems, and <em>Production AI Agents.</em></h1>
    <p class="lede">
      I am Özgür Güler, currently the AI Tech Lead at Microsoft Innovation Hub, Istanbul.
      I focus on AI inference systems and production AI agents: model serving, agentic
      workflows, EvalOps, governance, and the cloud architecture decisions that make AI
      systems work beyond the demo.
    </p>
  </section>

  <figure class="home-portrait">
    <img src={withBase("images/speaking/infobip-zagreb.jpeg")} alt="Özgür Güler speaking during an AI workshop." loading="eager" decoding="async" />
    <figcaption>Technical workshops on enterprise AI, agentic systems, and trustworthy deployment.</figcaption>
  </figure>

  <section class="section" aria-labelledby="focus-areas">
    <div class="section-head">
      <div>
        <span class="section-marker" aria-hidden="true">I.</span>
        <p class="eyebrow">Focus</p>
        <h2 id="focus-areas">Where I Focus</h2>
      </div>
    </div>
    <div class="focus-grid">
      <article class="focus-area">
        <svg class="focus-emblem" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <rect x="7" y="9" width="34" height="8" rx="2" stroke="currentColor" stroke-width="2" />
          <rect x="7" y="20" width="34" height="8" rx="2" stroke="currentColor" stroke-width="2" />
          <rect x="7" y="31" width="34" height="8" rx="2" stroke="currentColor" stroke-width="2" />
          <circle cx="12" cy="13" r="1.7" class="accent-fill" />
          <circle cx="12" cy="24" r="1.7" class="accent-fill" />
          <circle cx="12" cy="35" r="1.7" class="accent-fill" />
        </svg>
        <span class="focus-num">01</span>
        <h3>AI Inference Systems</h3>
        <p>AI inference systems, AI data-center buildouts, and sovereign AI / neocloud infrastructure.</p>
      </article>
      <article class="focus-area">
        <svg class="focus-emblem" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <line x1="24" y1="24" x2="24" y2="12" stroke="currentColor" stroke-width="2" />
          <line x1="24" y1="24" x2="13" y2="35" stroke="currentColor" stroke-width="2" />
          <line x1="24" y1="24" x2="35" y2="35" stroke="currentColor" stroke-width="2" />
          <circle cx="24" cy="9" r="3" stroke="currentColor" stroke-width="2" />
          <circle cx="11" cy="37" r="3" stroke="currentColor" stroke-width="2" />
          <circle cx="37" cy="37" r="3" stroke="currentColor" stroke-width="2" />
          <circle cx="24" cy="24" r="3.6" class="accent-fill" />
        </svg>
        <span class="focus-num">02</span>
        <h3>Production AI Agents</h3>
        <p>Productionising AI: EvalOps, governance, and the operational controls that keep agents reliable past the demo.</p>
      </article>
      <article class="focus-area">
        <svg class="focus-emblem" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <path d="M10 8 V38 H40" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M14 33 L21 25 L27 29 L37 15" class="accent-stroke" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="37" cy="15" r="2.4" class="accent-fill" />
        </svg>
        <span class="focus-num">03</span>
        <h3>Early-Stage AI Investment Work</h3>
        <p>Technical diligence for early-stage AI startups.</p>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="start-here">
    <div class="section-head">
      <div>
        <span class="section-marker" aria-hidden="true">II.</span>
        <p class="eyebrow">Start here</p>
        <h2 id="start-here">Choose the Right Shelf</h2>
      </div>
    </div>
    <ol class="index-list">
      {guideItems.map((item, index) => (
        <li>
          <a href={item.href}>
            <span class="idx-num">№&nbsp;{String(index + 1).padStart(2, "0")}</span>
            <span>
              <span class="idx-title">{item.title}</span>
              <span class="idx-blurb">{item.blurb}</span>
            </span>
            <span class="idx-kind">{item.kind}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="colophon" aria-labelledby="colophon">
    <div>
      <p class="col-mark" id="colophon">Özgür Güler<br /><em>AI Systems Builder.</em></p>
    </div>
    <div class="col-reach">
      <h3>Reach</h3>
      <div class="col-links">
        <a class="plausible-event-name=email_click" href="mailto:ozgur@graph-atlas.com">email</a>
        <a href="https://github.com/ozgurgulerx" target="_blank" rel="noopener">github</a>
        <a href="https://medium.com/@343544" target="_blank" rel="noopener">medium</a>
        <a href="https://www.goodreads.com/user/show/22619969-zg-r" target="_blank" rel="noopener">goodreads</a>
        <a href="https://www.linkedin.com/in/ozguler/" target="_blank" rel="noopener">linkedin</a>
        <a href="https://x.com/ozgurgulerx" target="_blank" rel="noopener">x.com</a>
      </div>
    </div>
  </section>
</BaseLayout>

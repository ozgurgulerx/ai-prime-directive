---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/links";

const areas = [
  "Serving topology and model routing",
  "Latency, throughput, batching, and scheduling",
  "KV-cache pressure and inference-time compute",
  "GPU economics and AI factory architecture",
  "Benchmarking, reliability, and observability",
];
---

<BaseLayout title="LLM Inference" description="LLM inference notes are grouped under the Build Log as model serving and AI infrastructure patterns.">
  <section class="hero">
    <p class="eyebrow">Moved section</p>
    <h1>LLM <em>Inference</em></h1>
    <p class="lede">The inference material now lives under the Build Log as a grouped public section rather than a page of individual repositories.</p>
    <div class="button-row">
      <a class="button primary" href={withBase("build-log/#llm-inference")}>LLM inference in build log</a>
    </div>
  </section>

  <section class="section">
    <div class="rows">
      {areas.map((item, index) => (
        <article class="row-card"><span class="meta">{String(index + 1).padStart(2, "0")}</span><h3>{item}</h3></article>
      ))}
    </div>
  </section>
</BaseLayout>

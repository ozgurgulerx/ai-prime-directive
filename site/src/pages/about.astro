---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";

const focus = ["production inference reliability", "agent architecture and context engineering", "evals, observability, and AI safety boundaries", "domain AI systems", "startup architecture and AI infrastructure market structure"];
---

<BaseLayout title="About" description="About Özgür Güler and this technical record.">
  <section class="hero">
    <p class="eyebrow">About</p>
    <h1>Özgür <em>Güler</em></h1>
    <p class="lede">I work around applied AI systems, cloud platforms, inference, agents, AI UX, and the practical details of getting AI products from prototype to production.</p>
  </section>

  <Section title="Current Focus">
    <div class="prose">
      <ul>{focus.map((item) => <li>{item}</li>)}</ul>
    </div>
  </Section>
</BaseLayout>

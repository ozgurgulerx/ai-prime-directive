---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { bookDraftLinks } from "@/lib/bookmarks";
---

<BaseLayout title="Books" description="Book drafts from the Safari Books- bookmarks folder.">
  <section class="hero">
    <p class="eyebrow">Books</p>
    <h1>Books</h1>
    <p class="lede">Book drafts from the Safari Books- bookmark folder. Each link opens the source Google Doc.</p>
  </section>

  <section class="section">
    <div class="grid two">
      {bookDraftLinks.map((book) => (
        <article class="card book-card">
          <a class="cover-link" href={book.url} target="_blank" rel="noopener" aria-hidden="true" tabindex="-1">
            <div class="cover-typo">
              <div class="cv-series">{book.series}</div>
              <div class="cv-title">
                {book.title}
                <span class="cv-author-name">Ozgur Guler</span>
              </div>
              <div class="cv-author">{book.status.toUpperCase()}</div>
            </div>
          </a>
          <div>
            <span class="status">{book.status}</span>
            <h3><a href={book.url} target="_blank" rel="noopener">{book.title}</a></h3>
            <p class="meta">Safari bookmark: {book.bookmarkTitle}</p>
            <p>{book.summary}</p>
            <div class="chips">
              {book.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

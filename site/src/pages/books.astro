---
import { existsSync } from "node:fs";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { bookDraftLinks } from "@/lib/bookmarks";

const publicDir = new URL("../../public/", import.meta.url);
const assetExists = (assetPath: string) => existsSync(new URL(assetPath.replace(/^\//, ""), publicDir));
const books = bookDraftLinks.map((book) => ({
  ...book,
  displayCover: assetExists(book.cover) ? book.cover : book.fallbackCover,
}));
---

<BaseLayout title="Books" description="Books currently in progress, available for free access and feedback.">
  <section class="hero">
    <p class="eyebrow">Books</p>
    <h1>Books</h1>
    <p class="lede">These books are currently in progress and available for free access. Each link opens the source Google Doc for reading and feedback.</p>
    <p class="lede">I strongly believe books in the AI era should be continuously rewritten, much like the continual learning paradigm. These drafts are my attempt to write continual-learning books: living technical references that stay open, improve over time, and invite feedback as the field changes.</p>
  </section>

  <section class="section">
    <div class="grid two">
      {books.map((book) => (
        <article class="card book-card">
          <a class="cover-link" href={book.url} target="_blank" rel="noopener" aria-hidden="true" tabindex="-1">
            <img
              class="book-cover"
              src={book.displayCover}
              data-fallback={book.fallbackCover}
              alt=""
              loading="lazy"
              decoding="async"
              onerror="this.onerror=null;this.src=this.dataset.fallback"
            />
          </a>
          <div>
            <span class="status">{book.status}</span>
            <h3><a href={book.url} target="_blank" rel="noopener">{book.title}</a></h3>
            <p class="meta">Open Google Doc</p>
            <p>{book.summary}</p>
            <div class="chips">
              {book.tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Card from "@/components/Card.astro";

const talks = (await getCollection("talks")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const topics = [
  { title: "AI Agents in Production", summary: "Architecture, tool use, memory, and the operational controls that keep agents reliable past the demo." },
  { title: "Building Successful AI Products", summary: "Product discovery, AI UX, evals, launch readiness, and adoption patterns for AI products that move beyond demos." },
  { title: "AI Inference Engineering", summary: "Serving stacks, routing, and the latency and cost tradeoffs behind a system that ships." },
  { title: "EvalOps and Observability", summary: "Building the evals, telemetry, and feedback loops that tell you whether an AI system is actually working." },
  { title: "AI Infrastructure", summary: "The platform layer underneath applied AI: compute, deployment shape, reliability, and governance." },
  { title: "RAG, Context Engineering, and Data Integration", summary: "Getting the right context to the model — retrieval, grounding, and the data plumbing around it." },
  { title: "AI Security", summary: "Threat models, guardrails, and the failure modes that matter once an AI system meets real users." },
  { title: "Startup AI Systems", summary: "Pragmatic architecture for small teams moving fast from prototype to a production cloud path." },
];
const formatDate = new Intl.DateTimeFormat("en", { month: "short", year: "numeric" });
---

<BaseLayout title="Talks and Workshops" description="Talks, private briefings, and workshops on production AI systems.">
  <section class="hero">
    <p class="eyebrow">Talks</p>
    <p class="eyebrow avail">booking 2026 · remote, london, or in-person</p>
    <h1>Talks and <em>Workshops</em></h1>
    <p class="lede">Talks, private briefings, and workshops on AI agents, inference systems, EvalOps, and AI infrastructure.</p>
    <div class="button-row">
      <a class="button cta plausible-event-name=talk_link_click" href="mailto:ozgur@graph-atlas.com?subject=AI%20Talk">book a talk</a>
      <a class="button" href="#workshop-topics">workshop topics</a>
    </div>
  </section>

  <div class="avail-strip">
    <span>booking now · talks · private briefings · workshops</span>
    <a class="button cta plausible-event-name=talk_link_click" href="mailto:ozgur@graph-atlas.com?subject=AI%20Talk">book a talk</a>
  </div>

  <Section title="Selected Talks">
    <div class="grid two">
      {
        talks.map((talk) => (
          <article class="card talk-card">
            {talk.data.video ? (
              <video
                class="card-media"
                controls
                muted
                playsinline
                preload="metadata"
                poster={talk.data.image}
                aria-label={talk.data.imageAlt ?? `${talk.data.title} talk video`}
              >
                <source src={talk.data.video} type="video/mp4" />
              </video>
            ) : talk.data.image && (
              <img
                class="card-media"
                src={talk.data.image}
                alt={talk.data.imageAlt ?? `${talk.data.title} talk photo`}
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="talk-body">
              {talk.data.type && <span class="status">{talk.data.type}</span>}
              <h3>{talk.data.title}</h3>
              <p class="meta">
                {formatDate.format(talk.data.date)}
                {talk.data.location ? ` · ${talk.data.location}` : ""}
              </p>
              <p>{talk.data.summary}</p>
              {talk.data.tags.length > 0 && (
                <div class="chips">
                  {talk.data.tags.map((tag) => <span class="chip">{tag}</span>)}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <Section id="workshop-topics" title="Workshop Topics">
    <div class="grid three">{topics.map((topic) => <Card title={topic.title} summary={topic.summary} />)}</div>
  </Section>

  <div class="contact-strip">
    <div>
      <h2>Book a Talk</h2>
      <p>Include the event or company, audience and technical level, format, topic, date/location/remote, budget range, and any other speakers or stakeholders.</p>
    </div>
    <div class="button-row"><a class="button cta plausible-event-name=talk_link_click" href="mailto:ozgur@graph-atlas.com?subject=AI%20Talk">book a talk</a></div>
  </div>
</BaseLayout>

<style>
  .eyebrow.avail {
    margin-top: 6px;
    color: var(--accent);
    text-transform: none;
    letter-spacing: 0.06em;
  }

  .avail-strip {
    margin-top: 40px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .talk-card {
    gap: 0;
  }

  .card-media {
    width: calc(100% + 48px);
    max-width: calc(100% + 48px);
    margin: -26px -24px 16px;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
    background: var(--paper-tint);
  }

  video.card-media {
    aspect-ratio: 16 / 9;
  }

  .talk-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
</style>

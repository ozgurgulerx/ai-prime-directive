---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Card from "@/components/Card.astro";

const talks = (await getCollection("talks")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const topics = ["AI agents in production", "AI inference engineering", "EvalOps and observability", "AI infrastructure", "RAG, context engineering, and data integration", "AI security", "Startup AI systems"];
const formatDate = new Intl.DateTimeFormat("en", { month: "short", year: "numeric" });
---

<BaseLayout title="Talks and Workshops" description="Talks, private briefings, and workshops on production AI systems.">
  <section class="hero">
    <p class="eyebrow">Talks</p>
    <h1>Talks and Workshops</h1>
    <p class="lede">Talks, private briefings, and workshops on AI agents, inference systems, EvalOps, and AI infrastructure.</p>
    <div class="button-row"><a class="button primary" href="mailto:ozgur@graph-atlas.com?subject=AI%20Talk">Book a Talk</a></div>
  </section>

  <Section title="Selected talks">
    <div class="grid two">
      {
        talks.map((talk) => (
          <article class="card talk-card">
            {talk.data.image && (
              <img
                class="card-media"
                src={talk.data.image}
                alt={talk.data.imageAlt ?? `${talk.data.title} talk photo`}
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="talk-body">
              {talk.data.type && <span class="status">{talk.data.type}</span>}
              <h3>{talk.data.title}</h3>
              <p class="meta">
                {formatDate.format(talk.data.date)}
                {talk.data.location ? ` · ${talk.data.location}` : ""}
              </p>
              <p>{talk.data.summary}</p>
              {talk.data.tags.length > 0 && (
                <div class="chips">
                  {talk.data.tags.map((tag) => <span class="chip">{tag}</span>)}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Workshop topics">
    <div class="grid three">{topics.map((topic) => <Card title={topic} />)}</div>
  </Section>

  <Section title="Book a talk">
    <div class="prose">
      <p>Please include event or company, audience, technical level, format, topic, date/location/remote, budget range, and stakeholders or other speakers.</p>
      <p><a class="button primary" href="mailto:ozgur@graph-atlas.com?subject=AI%20Talk">Email a talk request</a></p>
    </div>
  </Section>
</BaseLayout>

<style>
  .talk-card {
    gap: 0;
  }

  .card-media {
    width: calc(100% + 48px);
    max-width: calc(100% + 48px);
    margin: -26px -24px 16px;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
    background: var(--paper-tint);
  }

  .talk-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
</style>

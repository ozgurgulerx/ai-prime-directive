---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/links";

const areas = [
  "Memory, state, and forgetting policies",
  "Durable execution and long-running workflows",
  "Tool boundaries, MCP, and approval gates",
  "Evals, replay, and run-trace observability",
  "Governance and enterprise deployment",
];
---

<BaseLayout title="AI Agents" description="AI agent notes are grouped under the Build Log as durable software and deployment patterns.">
  <section class="hero">
    <p class="eyebrow">Moved section</p>
    <h1>AI <em>Agents</em></h1>
    <p class="lede">The AI Agents material now lives under the Build Log as a grouped public section rather than a page of individual repositories.</p>
    <div class="button-row">
      <a class="button primary" href={withBase("build-log/#ai-agents")}>AI agents in build log</a>
    </div>
  </section>

  <section class="section">
    <div class="rows">
      {areas.map((item, index) => (
        <article class="row-card"><span class="meta">{String(index + 1).padStart(2, "0")}</span><h3>{item}</h3></article>
      ))}
    </div>
  </section>
</BaseLayout>
